generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EntryType {
  VOEDING
  LUIER
  OPMERKING
  NOTITIE
}

model JournalEntry {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  timestamp DateTime
  entryType EntryType
  person    String?

  // Voeding fields (null when LUIER)
  amountMl  Int?
  braken    Boolean?  @default(false)

  // Luier fields (null when VOEDING)
  pipi      Boolean?  @default(false)
  kaka      Boolean?  @default(false)

  // Opmerking fields (null when not OPMERKING)
  remark    String?

  // Notitie fields — quick labels
  labels    String[]  @default([])

  @@index([timestamp])
}

model Label {
  id        String @id @default(cuid())
  name      String @unique
  sortOrder Int    @default(0)
  createdAt DateTime @default(now())
}
